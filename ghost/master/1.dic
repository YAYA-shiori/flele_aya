仩儊僯儏乕_index {



仜僿儖僾儊僯儏乕昞帵拞 = 1
	仩儊僯儏乕僿僢僟
--

_gtime=systemuphour-仜婲摦帪OS帪娫
// 乽%(_gtime)乿

"\v%(menu_bg)"
--
if 'for flele'_in_仜尰嵼僶儖乕儞 {"\_l[3,2]"}
--
// 嬋僀儞僼僅 -------------------------
  if 仜嬋偺悢 >=1 {"尰嵼慡%(fcl)"
		--
		if 仜儌乕僪=='CD' {
			_嬋悢=SAORI('saori\mcidonut.dll', 'trackcount')
			if _嬋悢<0{"--"}
			else{ _嬋悢 }
	}
		else {"%(仜嬋偺悢)"}
		--
		"%(def)嬋丂"
  --
	if 仜墘憈拞 == 1 { 


			//丂暥帤悢12傪墇偊偨傜徣棯
			if 仜嬋柤暥帤悢 > 12 {
				_敳偒弌偟 = SUBSTR ("%(仜墘憈拞嬋柤)",0,12)
				仜昞帵嬋柤 = "%(_敳偒弌偟)乧"
    				}
			else {仜昞帵嬋柤 = "%(仜墘憈拞嬋柤)"}
		if 仜儌乕僪=='CD' {
		"%(fcl)CD Track %(仜墘憈拞CD僩儔僢僋)%(def) 墘憈拞"
		}
		else {
		"%(fcl)%(仜昞帵嬋柤)%(def) 墘憈拞"
		}
	}
	else { "%(fcl)墘憈掆巭拞%(def)" }
  }
else {"尰嵼慡0嬋丂"}
--
	if 仜尰嵼僶儖乕儞=='for flele' {"\_l[0,94]"}
	elseif 仜尰嵼僶儖乕儞=='for flele / wide' {"\_l[0,110]"}
	else {'\n\n'}
--
// 僉乕僀儞僼僅 -------------------------
" %(傾僀僐儞2('point','仩'))僉乕憖嶌昞 乵\q[僐儞僼傿僌,仩僉乕愝掕_pre]乶\n[half]/
\n丂嵞惗 %(fcl)\f[bold,1]%(僉乕愝掕昞帵柤(0))\f[bold,default]%(def)丂掆巭/夝彍 %(fcl)\f[bold,1]%(僉乕愝掕昞帵柤(1))\f[bold,default]%(def)/
\n丂Menu %(fcl)\f[bold,1]%(僉乕愝掕昞帵柤(2))\f[bold,default]%(def)丂嬋柤敞菽蕹 %(fcl)\f[bold,1]%(僉乕愝掕昞帵柤(3))\f[bold,default]%(def)/
\n丂嬋僋儕傾 %(fcl)\f[bold,1]%(僉乕愝掕昞帵柤(4))\f[bold,default]%(def)丂廔椆 %(fcl)\f[bold,1]%(僉乕愝掕昞帵柤(5))\f[bold,default]%(def)/
"

--
// 1抜栚 -------------------------
"\n\n\n[half]丂%(傾僀僐儞('info','>')) \q[愢柧彂,仩readme奐偔]"
