if 仜儌乕僪!="CD" && 仜嬋偺悢 >= 1 && 仜婲摦拞墘憈夞 >= 1 {"丂 丂 丂 %(傾僀僐儞2('music'))\q[墘憈拞嬋忣曬,仩尰嵼嬋忣曬]"}
--
if 仜儌乕僪=="CD" {"丂 丂 丂 %(傾僀僐儞('cd','>')) \q[CD傪弌偡,仩CD庢傝弌偟]/\q[擖傟傞,仩CD擖傟]"}
