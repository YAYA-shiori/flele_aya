□m3u上書き出力 {

□m3u生成

--
if ○成否==1 {

_file=(SPLITPATH(○m3u出力パス)[2])+(SPLITPATH(○m3u出力パス)[3])

	"\0%(○サーフェス)\s[0]曲リスト%(fcl)”%(_file)”%(def)を出力しました。/
	\n\n　　\q[OPEN FOLDER,□m3uフォルダを開く]/
	\n　　　 \q[CLOSE,□close]/
	\w9\w9\w9\w9%(○サーフェス)/
	\e"
	}
else {
	"\0曲リスト出力に失敗しました。\e"
	}

}

□m3u生成 {
○成否 = 0
_di = (SPLITPATH(reference1)[0])+(SPLITPATH(reference1)[1])
_f = FDEL(_di+"\tmp.m3u")
_f = FDEL(○m3u出力パス)
FCHARSET (0)
if (FOPEN ("dat\tmp.m3u","w")) != 0 {
	foreach ○曲リスト ; _i {
		_i = 絶対パス変換(_i)
		FWRITE ("dat\tmp.m3u",_i)
		}
	FCLOSE ("dat\tmp.m3u")
	if (FCOPY ("dat\tmp.m3u",_di))==1 {
		○成否 = FRENAME (_di+"\tmp.m3u",○m3u出力パス)
		}
	}
}

