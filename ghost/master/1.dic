--

"%(アイコン2('point','□'))%(fcl)%(fcc)\q[音楽再生の設定,□再生設定]%(def)%(defc)\n\n[half]"
--
"%(アイコン2('point','□'))%(fcl)%(fcc)\q[動作設定,□動作設定]%(def)%(defc)\n\n"
--

"\n　　　　　　　\q[CLOSE,□close]｜\q[BACK,□メニュー_index]\e"
}

□動作設定 {
	□メニューヘッダ
--
": %(アイコン2('hotkey'))動作設定 :::::::::::::::::::::\n\n"
--


"%(アイコン2('point','□'))インアクティブ時%(fcl)Ctrl + Shift + Key%(def)でキー操作\n\n[half]"
--
if ○ホットキー操作=="ON" {"　　　　%(fcl)ON%(def) ［\q[変更,□ホットキーOFF]］"}
else {"　　　　%(fcl)OFF%(def)［\q[変更,□ホットキーON]］"}
--
"\n\n%(アイコン2('point','□'))曲リストメニュー(music list)を出す\n\n[half]"
--
if ○曲リストメニュー=="ON" {"　　　　%(fcl)ON%(def) ［\q[変更,□曲リストメニューOFF]］"}
else {"　　　　%(fcl)OFF%(def)［\q[変更,□曲リストメニューON]］"}
--

"\n\n[half]/
\n　　　　　　　\q[CLOSE,□close]｜\q[BACK,□設定]\e"
}



