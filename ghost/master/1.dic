	_i=1
	txt=""
	while _i<=_昞帵審悢 {
	_i++
	_僞僀僩儖 = ((EVAL("reference" + _i))[0])
	_僞僀僩儖 = (REPLACE(_僞僀僩儖, '[' , '乵'))
	_僞僀僩儖 = (REPLACE(_僞僀僩儖, ']' , '乶'))
	_僞僀僩儖 = (REPLACE(_僞僀僩儖, '\' , '\\'))
	_URL = (EVAL("reference" + _i))[1]
		if _URL != "" {
			if STRLEN(_僞僀僩儖) > 16 {
