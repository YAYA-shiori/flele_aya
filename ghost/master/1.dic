/// url drop ///////////////////////////////////////////////////

OnURLQuery {

if "audio" _in_ reference2 {
	仜URL=reference0
	仩URL偐傜嬋僟僂儞儘乕僪
	}

}

仩URL偐傜嬋僟僂儞儘乕僪 {

	//丂URL偑壒妝僼傽僀儖偐偳偆偐妋擣
	_奼挘巕 = TOLOWER ((SPLITPATH (仜URL))[3])
	if (ASEARCH(_奼挘巕,'.mid','.mp3','.wav','.wma','.ogg')) != -1 {
	仜DL奐巒 = 0
	仜DL惉岟 = 0
	仜URL = reference0
		"\0"
	--
	仜忋彂偒嬋DL=0
		_file = ((SPLITPATH (仜URL))[2])+((SPLITPATH (仜URL))[3])
file=_file
		if (FATTRIB("..\..\sound_file\%(_file)")) != -1 {
			"\b[0]婛偵摨偠柤慜偺僼傽僀儖偑僟僂儞儘乕僪偝傟偰偄傑偡丅\w5\n忋彂偒偟傑偡偐丠\w4\n[half]/
			\n丂丂丂 \q[OK,仩忋彂偒嬋僟僂儞儘乕僪]乥\q[NG,仩close]/
			\e"
		}
		else {仩嬋僟僂儞儘乕僪奐巒}
	}
}

仩忋彂偒嬋僟僂儞儘乕僪 {
	仜忋彂偒嬋DL=1
	仜墘憈拞 = 0
	仜僒乕僼僃僗 = "\s[0]"
	_i=SAORI("saori\mciaudior.dll", "stop")
	_僼傽僀儖柤 = ((SPLITPATH (仜URL))[2])+((SPLITPATH (仜URL))[3])
	_i=FDEL ("..\..\sound_file\%(_僼傽僀儖柤)")
--
仩嬋僟僂儞儘乕僪奐巒
}


仩嬋僟僂儞儘乕僪奐巒 {
		仜DL奐巒 = 1
		_file=(SPLITPATH(仜URL))[2]+(SPLITPATH(仜URL))[3]
		"\0\s[6]%(fcl)乭%(_file)乭%(def)\n now loading...\![execute,http-get,%(仜URL),--timeout=40,--async=soundfile,--file=%(_file)]\e"
}


OnExecuteHTTPComplete {
	if reference0=="get"&& reference1=="soundfile" {

		_僼傽僀儖柤 = ((SPLITPATH (仜URL))[2])+((SPLITPATH (仜URL))[3])
		//DL僼傽僀儖堏摦
		_i=FMOVE ( "var\%(_僼傽僀儖柤)","..\..\sound_file\" )
--
		if 仜忋彂偒嬋DL==1 {
		"\0\s[0]%(_僼傽僀儖柤)傪忋彂偒偟傑偟偨丅/
		\n\n[half]丂丂 \q[PLAY,仩忋彂偒嬋嵞惗]乥\q[CLOSE,仩close]/
		\e"
		仜忋彂偒嬋DL=0
		}
		else {
			_Filename = "..\..\..\sound_file\%(_僼傽僀儖柤)"
		
				//丂傑偩擖偭偰側偄側傜僟僂儞儘乕僪嬋儕僗僩偵捛壛
				if (ASEARCH(_Filename,仜僟僂儞儘乕僪嬋儕僗僩)) == -1 {
					if (ARRAYSIZE(仜僟僂儞儘乕僪嬋儕僗僩))==0 {
					仜僟僂儞儘乕僪嬋儕僗僩 = _Filename
					}
					else {仜僟僂儞儘乕僪嬋儕僗僩 = (仜僟僂儞儘乕僪嬋儕僗僩,_Filename)}
				}
				仜DL惉岟 = 1
				//丂僼傽僀儖僷僗傪AllFilepath偵曐懚偟張棟
				仜AllFilepath = _Filename
				仩僪儘僢僾僼傽僀儖張棟
		}
	}

}

OnExecuteHTTPFailure {"\0\s[6]\n\n丂> Download-error\w9\w9\w9\w9%(仜僒乕僼僃僗)\b[-1]\e"}


仩忋彂偒嬋嵞惗 {
_僼傽僀儖柤 = ((SPLITPATH (仜URL))[2])+((SPLITPATH (仜URL))[3])
_Filename = "..\..\..\sound_file\%(_僼傽僀儖柤)"
仜巜掕嬋斣崋=(ASEARCH(_Filename,仜嬋儕僗僩))+1
仩嬋儔儞僟儉嵞惗
}

