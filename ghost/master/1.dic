}

//CD1僩儔僢僋廔椆
OnMCIDonutTrackFinish {
	if 仜墘憈朄 == "one" {
	_i=SAORI("saori\mcidonut.dll", "stop")
	仜僒乕僼僃僗 = "\s[0]"
	仜墘憈拞 = 0
	"\0\s[0]\e"
	}
	elseif 仜墘憈朄 == "seq_one" {
		if 仜墘憈拞CD僩儔僢僋 == 仜CD僩儔僢僋悢 {
		_i=SAORI("saori\mcidonut.dll", "stop")
		仜僒乕僼僃僗 = "\s[0]"
		仜墘憈拞 = 0
		"\0\s[0]\e"
		}
		else {
		仜婲摦拞墘憈夞++
		仜墘憈拞CD僩儔僢僋++
		仜嵞惗帪娫懷[hour] = (仜嵞惗帪娫懷[hour])+1
		仩嬋柤僂傿儞僪僂ON側傜昞帵
		}
	}
	elseif 仜墘憈朄 == "loop" {
	仜巜掕嬋斣崋=仜墘憈拞CD僩儔僢僋
	仩嬋儔儞僟儉嵞惗
	}
	elseif 仜墘憈朄 == "seq_loop" {
		if 仜墘憈拞CD僩儔僢僋 == 仜CD僩儔僢僋悢 {
		仜巜掕嬋斣崋=1
		仩嬋儔儞僟儉嵞惗
		}
		else {
		仜婲摦拞墘憈夞++
		仜墘憈拞CD僩儔僢僋++
		仜嵞惗帪娫懷[hour] = (仜嵞惗帪娫懷[hour])+1
		仩嬋柤僂傿儞僪僂ON側傜昞帵
		}
	}
	else {
	_i=SAORI("saori\mcidonut.dll", "stop")
	仩嬋儔儞僟儉嵞惗
	}
}


