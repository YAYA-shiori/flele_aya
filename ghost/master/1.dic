□曲リストメニューON {○曲リストメニュー = "ON";□動作設定}





□再生設定 {
□演奏ストップ
--
	□メニューヘッダ
--
": %(アイコン2('hotkey'))音楽再生の設定 :::::::::::::::\n\n[half]"
--
"%(アイコン2('point','□'))モード\n\n[half]"
--
case  ○モード {
	when "CD" {"　　%(fcl)CD再生%(def)［\q[変更,□モードnormal]］"}
	others {
	
	"　　%(fcl)音楽ファイル再生%(def)"
	--
	//"［\q[変更,□モードCD]］"
	}
 }
--
"\n\n%(アイコン2('point','□'))再生方法\n\n[half]"
--
case ○演奏法 {
	when "one" {"　　 %(fcl)一曲を一度だけ再生%(def)［\q[変更,□演奏法loop]］"}
	when "loop" {"　　 %(fcl)同じ曲をエンドレス再生%(def)［\q[変更,□演奏法random]］"}
	when "seq_loop" {"　　 %(fcl)リスト順にエンドレス再生%(def)［\q[変更,□演奏法seq_one]］"}
	when "seq_one" {"　　 %(fcl)リスト順に一周だけ再生%(def)［\q[変更,□演奏法one]］"}
	others {"　　 %(fcl)ランダムでエンドレス再生%(def)［\q[変更,□演奏法seq_loop]］" }
}
--
"\n\n"
--
"%(アイコン2('point','□'))ogg再生設定\n\n[half]"
--
	if ○ogg設定=="mci" {
	"　　%(fcl)wavに変換して再生%(def)［\q[変更,□oggモードplaysound]］\n/
	（PlaySoundの衝突がなく一時停止できますが、重いです）"
	}
	else {
	
	"　　%(fcl)メモリ上に展開し再生%(def)［\q[変更,□oggモードmci]］\n/
	（軽いですが、PlaySoundの衝突があり一時停止できません）"
	}


--
"\n\n\n[half]　　　　　　　\q[CLOSE,□close]｜\q[BACK,□設定]\e"
}

□モードnormal {□曲を全て停止;○モード = "normal";□再生設定}
□モードCD { □曲を全て停止;○モード = "CD";□再生設定}

//同じ曲を繰り返し
□演奏法loop {○演奏法 = "loop";□再生設定}
//ランダムで延々と
□演奏法random {○演奏法 = "random";□再生設定}
//一度だけ再生
□演奏法one {○演奏法 = "one";□再生設定}
//曲順演奏繰り返し
□演奏法seq_loop {○演奏法 = "seq_loop";□再生設定}
//曲順に一周のみ
□演奏法seq_one {○演奏法 = "seq_one";□再生設定}




