仩僉乕慖戰 {
	_慖戰key = (REPLACE(reference0,"仩key_",""))
	_愝掕売強 = (TOINT((REPLACE(仜僀儀儞僩柤,"僉乕曄峏",""))))
	_i=_愝掕売強+20

	_壖僉乕攝楍 = (仜僉乕愝掕[20],仜僉乕愝掕[21],仜僉乕愝掕[22],仜僉乕愝掕[23],仜僉乕愝掕[24],仜僉乕愝掕[25])
	_壖僉乕攝楍[_愝掕売強]='_'
	if (ASEARCH(_慖戰key,_壖僉乕攝楍))!=-1 {
	仩儊僯儏乕僿僢僟
--
	仩僉乕僐儞僼傿僌僿僢僟
--
	"\0%(傾僀僐儞2('point','仩'))偦偺僉乕偼婛偵懠偺僔儑乕僩僇僢僩偵愝掕偝傟偰偄傑偡丅\_q\x"
	--
	仩僉乕愝掕
	}
	else {
		仜僉乕愝掕[_i]=_慖戰key
		--
		仩僉乕愝掕
	}
}

