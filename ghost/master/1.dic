			}
		txt = txt + "%(_i-1)丒\q[%(_僞僀僩儖),%(ASC(4))RSSURL_%(_URL)]\n[half]\n"
		}
	}
	--
	txt
	--
	"丂丂丂丂丂丂丂丂\q[CLOSE,仩close]"

--
"\e"
}


