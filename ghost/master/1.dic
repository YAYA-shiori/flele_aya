_dpath=(SUBSTR(_dpath,0,_i))

"\0\![open,file,%(_dpath)]\c"
--
仩嬋儕僗僩弌椡
}

仩m3u僼傽僀儖柤曄峏 {"\![open,inputbox,m3u_f,-1,%(仜m3u僼傽僀儖柤)]"}

