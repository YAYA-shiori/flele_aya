□曲リストクリア {
_ダウンロード曲数 = (ARRAYSIZE(○ダウンロード曲リスト))
□ヘルプメニュー消滅した
--
　// 曲が一曲以上あれば実行
   if ○曲の数 >= 1 {
   	if _ダウンロード曲数 >= 1 {
	"\0\s[0]曲リスト全%(○曲の数)曲をクリア、\w3ダウンロード曲全%(_ダウンロード曲数)曲を削除します。\w5宜しいですか？"
	}
	else {
	"\0\s[0]曲リスト、\w2全%(○曲の数)曲をクリアします。\n\w4/
	宜しいですか？\w5\n[half]"
	}
--
"\n　　　 \q[OK,□曲リストクリア実行]｜\q[NG,□close]\e"
   }
   // 曲がなかった
   else { "\0\s[0]曲リストにはまだ何もありません。\e" }
}

□曲リストクリア実行 {
	//　ダウンロードした曲を全て削除
	foreach ○ダウンロード曲リスト ; _Filename {
	_ファイル削除 = FDEL("\"+_Filename)
	}
	○曲リスト = IARRAY
	○ダウンロード曲リスト = IARRAY
	○曲リスト更新=1
	ERASEVAR('○演奏中曲パス')
	--
	□演奏ストップ
	--
	"\cクリアしました。\e"
	--
	□曲名ウィンドウONなら表示
}



