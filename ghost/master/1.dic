--
仩嬋忣曬拞恎
--
"\n[half]/
\n丂丂丂丂丂丂丂丂\q[CLOSE,仩close]\e"
}

On_weirds嬋僼僅儖僟傪奐偔 {
仩weirds嬋僼僅儖僟
}

仩weirds嬋僼僅儖僟 {
_path = 仜嬋儕僗僩[reference0]
_dpath = ((SPLITPATH(_path))[0])+((SPLITPATH(_path))[1])
if _dpath == "..\..\..\sound_file\" {_dpath = "..\..\sound_file"}
else {
	_i=(STRLEN(_dpath))-1
	_dpath=(SUBSTR(_dpath,0,_i))
	}
"\0\![open,file,%(_dpath)]\e"
}


仜weirdsCD儊僯儏乕 {

//僉儍僢僔儏峏怴
	if 仜CD僩儔僢僋悢>0 {
	仩weirdsCD儕僗僩惗惉

	}
	else {"%(ASC(1))%(ASC(1))丂丂 no data%(ASC(1))Dummy%(ASC(2))"}
--
"%(ASC(1))%(ASC(1))%(ASC(1))Separator%(ASC(2))"
--
	仩weirds嵞惗朄("儔儞僟儉偱僄儞僪儗僗","儔儞僟儉偱楢懕嵞惗","random")
--
	仩weirds嵞惗朄("儕僗僩弴偵僄儞僪儗僗","seq_loop")
--
	仩weirds嵞惗朄("儕僗僩弴偵堦廃偩偗","seq_one")
--
	仩weirds嵞惗朄("堦嬋傪堦搙偩偗","one")
--
	仩weirds嵞惗朄("摨偠嬋傪僄儞僪儗僗","loop")
--
"/
%(ASC(1))%(ASC(1))%(ASC(1))Separator%(ASC(2))/
%(ASC(1))%(ASC(1))CD傪庢傝弌偡%(ASC(1))Event%(ASC(1))On_CD傪庢傝弌偡%(ASC(2))/
%(ASC(1))%(ASC(1))CD傪僙僢僩偡傞%(ASC(1))Event%(ASC(1))On_CD傪僙僢僩偡傞%(ASC(2))/
"
}

仩weirds嵞惗朄 {

"嵞惗朄曄峏%(ASC(1))"
--
if 仜墘憈朄==_argv[1] ; "C"
elseif (ISVAR("仜墘憈朄"))==0 && _argv[1]=="random" ; "C"
--
"%(ASC(1))%(_argv[0])%(ASC(1))"
--
if 仜墘憈朄==_argv[1] ; "Dummy"
elseif (ISVAR("仜墘憈朄"))==0 && _argv[1]=="random" ; "Dummy"
else {"Event"}
--
"%(ASC(1))On_嵞惗朄曄峏%(ASC(1))%(_argv[1])%(ASC(2))"
}


仩weirdsCD儕僗僩惗惉 {
ERASEVAR("仜weirds儕僗僩")
_c=0

	//20嬋埲壓側傜僼僅儖僟偵偄傟側偄
	if 仜CD僩儔僢僋悢<=20 {
		for _c = 1 ; _c <= 仜CD僩儔僢僋悢 ; _c++ {
		仜weirds儕僗僩 = 仜weirds儕僗僩  + ASC(1) + ASC(1) + "Track %(_c)" + ASC(1) + "Event" + ASC(1) + "On_weirdsCD巜掕嵞惗" + ASC(1) + _c + ASC(2)
		}
	}
	else {
		for _c = 1 ; _c <= 仜CD僩儔僢僋悢 ; _c++ {
		_僼僅儖僟 = (_c/25)*25+25
		仜weirds儕僗僩 = 仜weirds儕僗僩 + "乣 " + _僼僅儖僟  + ASC(1) + ASC(1) + "Track %(_c)" + ASC(1) + "Event" + ASC(1) + "On_weirdsCD巜掕嵞惗" + ASC(1) + _c + ASC(2)
		}
	}

仜weirds儕僗僩
仜CD嬋儕僗僩峏怴=0
}

On_weirdsCD巜掕嵞惗 {
仜巜掕嬋斣崋 = 0
仜巜掕嬋斣崋 = TOINT(reference0)
仩嬋儔儞僟儉嵞惗
}

