	"\0%(仜僒乕僼僃僗)\s[0]\b[-1]\w9\b[1]乧\w7乧\w7乧\w7乧\w7乧\w7乧\w7丅\w9\w9\w9\w9%(仜僒乕僼僃僗)\e"
	}
}


OnCommunicate {

