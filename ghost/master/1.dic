仩弌椡愭僨傿儗僋僩儕曄峏 {
_path=仩僼傽僀儖慖戰僟僀傾儘僌

_奼挘巕=TOLOWER((SPLITPATH(_path))[3])

		if FATTRIB((SPLITPATH(_path)[0])+(SPLITPATH(_path)[1]))[2] != 1 || _path==0 {
		仩嬋儕僗僩弌椡
		}
		elseif _奼挘巕!=".m3u" {
			"m3u僼傽僀儖傪慖戰偡傞偐丄.m3u偺晅偄偨僼傽僀儖柤傪擖椡偟偰偔偩偝偄丅\n[half]/
			\n丂 \q[CLOSE,仩close]乥\q[RETRY,仩弌椡愭僨傿儗僋僩儕曄峏]/
			\e"
		}
		else {
			仜m3u弌椡僷僗=_path
			仩嬋儕僗僩弌椡
		}



}

//"\![open,inputbox,m3u_d,-1,%(仜m3u弌椡僷僗)]"

仩m3u僼僅儖僟傪奐偔 {
