仩嵞惗愝掕 {
仩墘憈僗僩僢僾
--
	仩儊僯儏乕僿僢僟
--
": %(傾僀僐儞2('hotkey'))壒妝嵞惗偺愝掕 :::::::::::::::\n\n[half]"
--
"%(傾僀僐儞2('point','仩'))儌乕僪\n\n[half]"
--
case  仜儌乕僪 {
	when "CD" {"丂丂%(fcl)CD嵞惗%(def)乵\q[曄峏,仩儌乕僪normal]乶"}
	others {
	
	"丂丂%(fcl)壒妝僼傽僀儖嵞惗%(def)"
	--
	//"乵\q[曄峏,仩儌乕僪CD]乶"
	}
 }
--
"\n\n%(傾僀僐儞2('point','仩'))嵞惗曽朄\n\n[half]"
--
case 仜墘憈朄 {
	when "one" {"丂丂 %(fcl)堦嬋傪堦搙偩偗嵞惗%(def)乵\q[曄峏,仩墘憈朄loop]乶"}
	when "loop" {"丂丂 %(fcl)摨偠嬋傪僄儞僪儗僗嵞惗%(def)乵\q[曄峏,仩墘憈朄random]乶"}
	when "seq_loop" {"丂丂 %(fcl)儕僗僩弴偵僄儞僪儗僗嵞惗%(def)乵\q[曄峏,仩墘憈朄seq_one]乶"}
	when "seq_one" {"丂丂 %(fcl)儕僗僩弴偵堦廃偩偗嵞惗%(def)乵\q[曄峏,仩墘憈朄one]乶"}
	others {"丂丂 %(fcl)儔儞僟儉偱僄儞僪儗僗嵞惗%(def)乵\q[曄峏,仩墘憈朄seq_loop]乶" }
}
--
"\n\n"
--
"%(傾僀僐儞2('point','仩'))ogg嵞惗愝掕\n\n[half]"
--
	if 仜ogg愝掕=="mci" {
	"丂丂%(fcl)wav偵曄姺偟偰嵞惗%(def)乵\q[曄峏,仩ogg儌乕僪playsound]乶\n/
	乮PlaySound偺徴撍偑側偔堦帪掆巭偱偒傑偡偑丄廳偄偱偡乯"
	}
	else {
	
	"丂丂%(fcl)儊儌儕忋偵揥奐偟嵞惗%(def)乵\q[曄峏,仩ogg儌乕僪mci]乶\n/
	乮寉偄偱偡偑丄PlaySound偺徴撍偑偁傝堦帪掆巭偱偒傑偣傫乯"
	}


--
"\n\n\n[half]丂丂丂丂丂丂丂\q[CLOSE,仩close]乥\q[BACK,仩愝掕]\e"
}

仩儌乕僪normal {仩嬋傪慡偰掆巭;仜儌乕僪 = "normal";仩嵞惗愝掕}
仩儌乕僪CD { 仩嬋傪慡偰掆巭;仜儌乕僪 = "CD";仩嵞惗愝掕}

//摨偠嬋傪孞傝曉偟
仩墘憈朄loop {仜墘憈朄 = "loop";仩嵞惗愝掕}
//儔儞僟儉偱墑乆偲
仩墘憈朄random {仜墘憈朄 = "random";仩嵞惗愝掕}
//堦搙偩偗嵞惗
仩墘憈朄one {仜墘憈朄 = "one";仩嵞惗愝掕}
//嬋弴墘憈孞傝曉偟
仩墘憈朄seq_loop {仜墘憈朄 = "seq_loop";仩嵞惗愝掕}
//嬋弴偵堦廃偺傒
仩墘憈朄seq_one {仜墘憈朄 = "seq_one";仩嵞惗愝掕}




