\n/
%(アイコン2('point','□'))曲再生　　　　［%(キー設定表示名(20))］［\q[変更,□曲再生キー変更]］\n\n[half]/
%(アイコン2('point','□'))一時停止　　　［%(キー設定表示名(21))］［\q[変更,□一時停止キー変更]］\n\n[half]/
%(アイコン2('point','□'))メニュー　　　［%(キー設定表示名(22))］［\q[変更,□メニューキー変更]］\n\n[half]/
%(アイコン2('point','□'))曲名ウィンドウ［%(キー設定表示名(23))］［\q[変更,□曲ウィンドウキー変更]］\n\n[half]/
%(アイコン2('point','□'))曲クリア　　　［%(キー設定表示名(24))］［\q[変更,□曲クリアキー変更]］\n\n[half]/
%(アイコン2('point','□'))終了　　　　　［%(キー設定表示名(25))］［\q[変更,□終了キー変更]］\n\n[half]/
\n　　　　　　［\q[これで決定,□キー設定完了]］/
"
--
"\n\n\n[half]　　　　　　 \q[CLOSE,□close]｜\q[BACK,□メニュー_index]\e"
}


キー設定表示名 {

_i=TOINT(_argv[0])
_キー名=(○キー設定[(_i)])


	if (_キー名) == 'up'			{'↑'}
	elseif (_キー名) == 'left'		{'←'}
	elseif (_キー名) == 'down'		{'↓'}
	elseif (_キー名) == 'right'		{'→'}
	elseif (_キー名) == ':'			{'*'}
	elseif (_キー名) == ';'			{'+'}
	elseif (_キー名) == 'return'	{'enter'}
	//「/」の時
	elseif (_キー名) == (CHR(0x2f))	{'?'}
	//「\の時」
	elseif (_キー名) == '￥'	{'\\'}
	elseif (STRLEN(_キー名))<=1||(SUBSTR(_キー名,0,1))=='f' {
		TOUPPER(_キー名)
		}
	else {(_キー名)}


}


