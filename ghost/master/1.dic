/// weirds /////////////////////////////////////////////////////


仩weirds {
仜僿儖僾儊僯儏乕昞帵拞 = 0
_i=SAORI("saori\Weirds.dll", "show", "/
//儊僯儏乕
%(ASC(1))%(ASC(1))丂- music list -%(ASC(1))Dummy%(ASC(2))/
%(ASC(1))%(ASC(1))%(ASC(1))Separator%(ASC(2))/
%(仩weirds嬋儊僯儏乕敾暿)/
","/
//僨僓僀儞
background.font.color%(ASC(1))0,0,0%(ASC(2))/
background.base.color%(ASC(1))255,255,255%(ASC(2))/
foreground.font.color%(ASC(1))%(mffc)%(ASC(2))/
foreground.base.color%(ASC(1))%(mfbc)%(ASC(2))/
menu.disable.font.color%(ASC(1))150,150,150%(ASC(2))/
menu.item.fontname%(ASC(1))MS UI Gothic%(ASC(2))/
sidebar.base.color%(ASC(1))255,255,255%(ASC(2))/
menu.item.width%(ASC(1))100%(ASC(2))/
sidebar.width%(ASC(1))0%(ASC(2))/
")
--
"\e"
}
//%(fbgc)

仩weirds嬋儊僯儏乕敾暿 {
	if 仜儌乕僪=="CD" { 仜weirdsCD儊僯儏乕 }
	else { 仜weirds嬋儊僯儏乕 }
}

仜weirds嬋儊僯儏乕 {
if 仜嬋偺悢>=1 {
//僉儍僢僔儏峏怴
if 仜嬋儕僗僩峏怴!=0 {仩weirds儕僗僩惗惉}
--
"/

%(REPLACE(仜weirds儕僗僩,ASC(4),'嵞惗'))/

%(REPLACE(仜weirds儕僗僩,ASC(4),'忣曬'))/

%(REPLACE(仜weirds儕僗僩,ASC(4),'僼僅儖僟傪奐偔'))/

%(REPLACE(仜weirds儕僗僩,ASC(4),'嶍彍'))/

"
	}
	else {"%(ASC(1))%(ASC(1))丂丂 no data%(ASC(1))Dummy%(ASC(2))"}
--
"%(ASC(1))%(ASC(1))%(ASC(1))Separator%(ASC(2))"
--
	仩weirds嵞惗朄("儔儞僟儉偱僄儞僪儗僗","儔儞僟儉偱楢懕嵞惗","random")
--
	仩weirds嵞惗朄("儕僗僩弴偵僄儞僪儗僗","seq_loop")
--
	仩weirds嵞惗朄("儕僗僩弴偵堦廃偩偗","seq_one")
--
	仩weirds嵞惗朄("堦嬋傪堦搙偩偗","one")
--
	仩weirds嵞惗朄("摨偠嬋傪僄儞僪儗僗","loop")
--
}





仩weirds儕僗僩惗惉 {
ERASEVAR("仜weirds儕僗僩")
//仜嬋儕僗僩攝楍偺奺梫慺抣傪弴斣偵庢傝弌偟
_c=0
  //25嬋埲壓側傜僼僅儖僟偵偄傟側偄
  if 仜嬋偺悢<=25 {
	foreach 仜嬋儕僗僩 ; _i {
	// 僼傽僀儖柤傪嬋柤偵
	_嬋柤 = ((SPLITPATH (_i))[2]) + ((SPLITPATH (_i))[3])

	仜weirds儕僗僩 = 仜weirds儕僗僩 + ASC(4) + ASC(1) + ASC(1) + _嬋柤 + ASC(1) + "Event" + ASC(1) + "On_weirds嬋%(ASC(4))" + ASC(1) + _c + ASC(2)
	_c++
	}
  }
  else {
	foreach 仜嬋儕僗僩 ; _i {
	// 僼傽僀儖柤傪嬋柤偵
	_嬋柤 = ((SPLITPATH (_i))[2]) + ((SPLITPATH (_i))[3])
	_僼僅儖僟 = (_c/25)*25+25
	仜weirds儕僗僩 = 仜weirds儕僗僩 + ASC(4) + "\" + "乣 " + _僼僅儖僟 + ASC(1) + ASC(1) + _嬋柤 + ASC(1) + "Event" + ASC(1) + "On_weirds嬋%(ASC(4))" + ASC(1) + _c + ASC(2)
	_c++

	}
  }


仜嬋儕僗僩峏怴=0
}

On_weirds嬋嵞惗 {
仜巜掕嬋斣崋 = TOINT(reference0)+1
仩嬋儔儞僟儉嵞惗
}

On_嬋儔儞僟儉嵞惗 {
仩嬋儔儞僟儉嵞惗
}

On_weirds嬋嶍彍 {
//嬋偺悢偑侾偺応崌慡偰徚嫀
if 仜嬋偺悢<=1 {
	仩墘憈僗僩僢僾
	--
	仜嬋儕僗僩 = IARRAY
	FDEL(仜僟僂儞儘乕僪嬋儕僗僩)
	仜僟僂儞儘乕僪嬋儕僗僩 = IARRAY
	}
else {
	_i=仜嬋儕僗僩[(TOINT(reference0))]
	if 仜墘憈拞嬋僷僗==_i {
		ERASEVAR('仜墘憈拞嬋僷僗')
		仩墘憈僗僩僢僾
		}
	//僟僂儞儘乕僪嬋偐偳偆偐挷傋傞
	_d = ASEARCH(reference0,仜僟僂儞儘乕僪嬋儕僗僩)
	//僟僂儞儘乕僪嬋偩偭偨傜偦傟傕嶍彍
	if _d != -1 { 
		FDEL(仜僟僂儞儘乕僪嬋儕僗僩[_d]) 
		//儕僗僩偐傜傕嶍彍
		if (ARRAYSIZE(仜僟僂儞儘乕僪嬋儕僗僩))<=1 {仜僟僂儞儘乕僪嬋儕僗僩 = IARRAY}
		else {仜僟僂儞儘乕僪嬋儕僗僩[_d] = IARRAY }
		}
	仜嬋儕僗僩[(TOINT(reference0))] = IARRAY
	}
仜嬋儕僗僩峏怴=1
}

On_嬋儕僗僩僋儕傾 {
"\0\v"
--
仩嬋儕僗僩僋儕傾
}

On_weirds嬋忣曬 {
