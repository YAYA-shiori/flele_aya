□weirds {
○ヘルプメニュー表示中 = 0
_i=SAORI("saori\Weirds.dll", "show", "/
//メニュー
%(ASC(1))%(ASC(1))　- music list -%(ASC(1))Dummy%(ASC(2))/
%(ASC(1))%(ASC(1))%(ASC(1))Separator%(ASC(2))/
