	_i=SAORI("saori\bln.dll", "win01", "", "0", "0", "kyokumei")
}

//丂嬋柤昞帵峏怴
仩僂傿儞僪僂偵嬋柤昞帵 {
	_i=SAORI("saori\bln.dll", "win01", "%(仜僂傿儞僪僂昞帵梡嬋柤)", "0", "0", "kyokumei", "1")
}

//丂嬋柤僂傿儞僪僂ON偺応崌壗偐偁偭偰堦帪揑偵旕昞帵偵偟偨屻嵞昞帵
仩嬋柤僂傿儞僪僂ON側傜昞帵 {
if 仜嬋柤僂傿儞僪僂ON == 1	{仩僂傿儞僪僂偵嬋柤昞帵}
}

仜僂傿儞僪僂昞帵梡嬋柤 {
if 仜墘憈拞 == 1 {

	if 仜儌乕僪 == "CD" {仜僫儞僶乕=仜墘憈拞CD僩儔僢僋}
	else {仜僫儞僶乕=仜墘憈拞嬋No}

			//丂暥帤悢18傪墇偊傞偲徣棯
			if 仜嬋柤暥帤悢 > 18 {
				_敳偒弌偟 = SUBSTR ("%(仜墘憈拞嬋柤)",0,18)
				仜昞帵嬋柤 = "%(_敳偒弌偟)乧"
    				}
			else {仜昞帵嬋柤 = "%(仜墘憈拞嬋柤)"}
			
			// 嬋No埵抲挷惍
			_嬋No暥帤悢 = STRLEN (仜僫儞僶乕)
				if _嬋No暥帤悢==1 { 仜嬻敀 = "\_q丂" }
				elseif _嬋No暥帤悢==2 { 仜嬻敀 = "\_q%(CHR(0x20))" }
				else { 仜嬻敀 = "\_q" }
				
	//丂昞帵

		if 仜儌乕僪 == "CD" {
		"%(仜嬻敀)%(仜墘憈拞CD僩儔僢僋)/%(仜CD僩儔僢僋悢)\_q丂CD - Track %(仜墘憈拞CD僩儔僢僋)"
		}
		else {
		"%(仜嬻敀)%(仜僫儞僶乕)/%(仜嬋偺悢)\_q %(仜昞帵嬋柤)"
		}
}
else {
	if 仜儌乕僪 == "CD" {"\_q丂0/%(仜CD僩儔僢僋悢) - NO PLAYING -\_q"}
	else {"\_q丂0/%(仜嬋偺悢) - NO PLAYING -\_q"}

}
}

