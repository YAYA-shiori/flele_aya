	"\b[4]"
	}
	else {
	"\b[2]"
	}
--
"\![set,autoscroll,disable]\*\_q"
--
	//タイトル//
	"%(fcl)”%(reference0)”%(def)\n[half]\n"
	--
	//本文//
	_本文 = reference3

	"%(_本文)\n[half]"
	--
	//リンク//
	if reference2 == "First" || reference2 == "Next" {
	"　　　\q[OPEN BROWSER,%(reference1)]｜\q[CLOSE,□close]｜\q[NEXT,]"
	}
	else {
	"　　　　\q[OPEN BROWSER,%(reference1)]｜\q[CLOSE,□close]"
	}
--
"\e"
}

