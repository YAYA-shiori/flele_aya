//ExtractMP3慡斒
嬋夝愅 {
_i = SAORI("saori\KI.dll","ExtractMP3",仜path,_argv[0])
if (ASEARCH(_i,'id3 tag(v1) is not found','Target Not Found','204 No Content','arg0 is error','arg1 is error','arg2 is error')) != -1 {_i=''}
_i = REPLACE(_i,"[","乵")
_i = REPLACE(_i,"]","乶")
_i = REPLACE(_i,"\","亸")
_i
}

僕儍儞儖斣崋夝愅 {
_i = SAORI("saori\KI.dll","ExtractMP3",仜path,"GetGenre")
if _i==255 {""}
elseif _i>=0 && _i<=147 {
	僕儍儞儖斣崋[(_i)]
	}
elseif _i==248 {'Heavy Rock'}
elseif _i==249 {'Doom Rock'}
elseif _i==250 {'J-POP'}
elseif _i==251 {'Seiyu'}
elseif _i==252 {'Tecno Ambient'}
elseif _i==253 {'Moemoe'}
elseif _i==254 {'Tokusatsu'}
else {''}
}


