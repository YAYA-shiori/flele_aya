仜僉乕愝掕[1]=_key1
仜僉乕愝掕[2]=_key2
仜僉乕愝掕[3]=_key3
仜僉乕愝掕[4]=_key4
仜僉乕愝掕[5]=_key5
	if 仜儂僢僩僉乕憖嶌=="ON" {
	SAORI("saori\hotkey.dll")
	仩儂僢僩僉乕弨旛
	}
	仩儊僯儏乕僿僢僟
