仩m3u惗惉 {
仜惉斲 = 0
_di = (SPLITPATH(reference1)[0])+(SPLITPATH(reference1)[1])
_f = FDEL(_di+"\tmp.m3u")
_f = FDEL(仜m3u弌椡僷僗)
FCHARSET (0)
if (FOPEN ("dat\tmp.m3u","w")) != 0 {
	foreach 仜嬋儕僗僩 ; _i {
		_i = 愨懳僷僗曄姺(_i)
		FWRITE ("dat\tmp.m3u",_i)
		}
	FCLOSE ("dat\tmp.m3u")
	if (FCOPY ("dat\tmp.m3u",_di))==1 {
		仜惉斲 = FRENAME (_di+"\tmp.m3u",仜m3u弌椡僷僗)
		}
	}
}

