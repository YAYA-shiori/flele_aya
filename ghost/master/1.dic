"%(傾僀僐儞2('point','仩'))愝掕偟偨偄僉乕傪慖戰偟偰偔偩偝偄丅\n/
\n/
\q[ A ,仩key_a]\q[ B ,仩key_b]\q[ C ,仩key_c]\q[ D ,仩key_d]\q[ E ,仩key_e]\q[ F ,仩key_f]\q[ G ,仩key_g]\q[ H ,仩key_h]\q[ I ,仩key_i]\q[ J ,仩key_j]\q[ K ,仩key_k]\q[ L ,仩key_l]\n/
\q[ M ,仩key_m]\q[ N ,仩key_n]\q[ O ,仩key_o]\q[ P ,仩key_p]\q[ Q ,仩key_q]\q[ R ,仩key_r]\q[ S ,仩key_s]\q[ T ,仩key_t]\q[ U ,仩key_u]\q[ V ,仩key_v]\q[ W ,仩key_w]\q[ X ,仩key_x]\n/
\q[ Y ,仩key_y]\q[ Z ,仩key_z]\n/
\n \q[enter,仩key_return]丂\q[space,仩key_space]丂\q[backspace,仩key_back]丂\q[tab,仩key_tab]/
\n \q[insert,仩key_insert]丂\q[delete,仩key_delete]/
\n/
