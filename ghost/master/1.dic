//丂僇乕僜儖堏摦
OnMouseMove
{
 if reference3 == 0
 {
 //---- 杮懱懁偺晱偱

	if reference4 != ""
	{
		//----偳偙偐偑晱偱傜傟偰偄傞
		stroke++
		//---- 晱偱傜傟偨検偑堦掕検偵払偟偨傜乽側偱傜傟偰偄傞乿偲敾抐
		if stroke >= 80
		{
			//---- 晱偱傜傟偨丅晱偱傜傟偨晹埵傪尒偰僩乕僋偡傞
			if reference4 == "stroke_p"
			{
				仩晱偱斀墳
			}
			elseif 仜尰嵼僔僃儖=="Sorcerer-F" && reference4 == "stop_button1"
			{
				仩晱偱斀墳
			}
			stroke = 0
		}
	}
	else
	{
		// 掕媊偝傟偨晹埵偼偳偙傕晱偱傜傟偰偄側偄
		stroke = 0
	}

 }
}
