□weirdsCDリスト生成 {
ERASEVAR("○weirdsリスト")
_c=0

	//20曲以下ならフォルダにいれない
	if ○CDトラック数<=20 {
		for _c = 1 ; _c <= ○CDトラック数 ; _c++ {
		○weirdsリスト = ○weirdsリスト  + ASC(1) + ASC(1) + "Track %(_c)" + ASC(1) + "Event" + ASC(1) + "On_weirdsCD指定再生" + ASC(1) + _c + ASC(2)
		}
	}
	else {
		for _c = 1 ; _c <= ○CDトラック数 ; _c++ {
		_フォルダ = (_c/25)*25+25
		○weirdsリスト = ○weirdsリスト + "～ " + _フォルダ  + ASC(1) + ASC(1) + "Track %(_c)" + ASC(1) + "Event" + ASC(1) + "On_weirdsCD指定再生" + ASC(1) + _c + ASC(2)
		}
	}

○weirdsリスト
○CD曲リスト更新=0
