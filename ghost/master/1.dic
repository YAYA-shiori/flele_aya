仩僉乕僐儞僼傿僌僿僢僟 {": %(傾僀僐儞2('keycon'))僉乕僐儞僼傿僌 :::::::::::::::\n\n[half]"}

仩僉乕愝掕 {
	仩儊僯儏乕僿僢僟
--
	仩僉乕僐儞僼傿僌僿僢僟
--
"僔儑乕僩僇僢僩僉乕偺乵曄峏乶偐傜愝掕傪曄峏偟丄寛傑偭偨傜乵偙傟偱寛掕乶傪僋儕僢僋偟偰偔偩偝偄丅\n/
\n/
%(傾僀僐儞2('point','仩'))嬋嵞惗丂丂丂丂乵%(僉乕愝掕昞帵柤(20))乶乵\q[曄峏,仩嬋嵞惗僉乕曄峏]乶\n\n[half]/
%(傾僀僐儞2('point','仩'))堦帪掆巭丂丂丂乵%(僉乕愝掕昞帵柤(21))乶乵\q[曄峏,仩堦帪掆巭僉乕曄峏]乶\n\n[half]/
%(傾僀僐儞2('point','仩'))儊僯儏乕丂丂丂乵%(僉乕愝掕昞帵柤(22))乶乵\q[曄峏,仩儊僯儏乕僉乕曄峏]乶\n\n[half]/
%(傾僀僐儞2('point','仩'))嬋柤僂傿儞僪僂乵%(僉乕愝掕昞帵柤(23))乶乵\q[曄峏,仩嬋僂傿儞僪僂僉乕曄峏]乶\n\n[half]/
%(傾僀僐儞2('point','仩'))嬋僋儕傾丂丂丂乵%(僉乕愝掕昞帵柤(24))乶乵\q[曄峏,仩嬋僋儕傾僉乕曄峏]乶\n\n[half]/
%(傾僀僐儞2('point','仩'))廔椆丂丂丂丂丂乵%(僉乕愝掕昞帵柤(25))乶乵\q[曄峏,仩廔椆僉乕曄峏]乶\n\n[half]/
\n丂丂丂丂丂丂乵\q[偙傟偱寛掕,仩僉乕愝掕姰椆]乶/
"
--
"\n\n\n[half]丂丂丂丂丂丂 \q[CLOSE,仩close]乥\q[BACK,仩儊僯儏乕_index]\e"
}


僉乕愝掕昞帵柤 {

_i=TOINT(_argv[0])
_僉乕柤=(仜僉乕愝掕[(_i)])


	if (_僉乕柤) == 'up'			{'仾'}
	elseif (_僉乕柤) == 'left'		{'仼'}
	elseif (_僉乕柤) == 'down'		{'伀'}
	elseif (_僉乕柤) == 'right'		{'仺'}
	elseif (_僉乕柤) == ':'			{'*'}
	elseif (_僉乕柤) == ';'			{'+'}
	elseif (_僉乕柤) == 'return'	{'enter'}
	//乽/乿偺帪
	elseif (_僉乕柤) == (CHR(0x2f))	{'?'}
	//乽\偺帪乿
	elseif (_僉乕柤) == '亸'	{'\\'}
	elseif (STRLEN(_僉乕柤))<=1||(SUBSTR(_僉乕柤,0,1))=='f' {
		TOUPPER(_僉乕柤)
		}
	else {(_僉乕柤)}


}


