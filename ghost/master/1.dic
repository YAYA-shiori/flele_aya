OnUserInput {
"\0"
--
//丂嬻懪偪妋擣
 if reference1 == "" {
	"\b[-1]"
	}
else {
//丂InputBoxID妋擣
  if reference0 == "url" {
		//丂URL偩偭偨傜僟僂儞儘乕僪
		if "http://" _in_ reference1 {
			仜URL = reference1
			仩URL偐傜嬋僟僂儞儘乕僪
			}
		elseif !reference1 {"\0\b[-1]\e"} 
		//丂URL偠傖側偐偭偨傜寈崘
		else {"僒僂儞僪僼傽僀儖偺URL傪擖椡偟偰偔偩偝偄丅\n[half]/
		\n丂 \q[CLOSE,仩close]乥\q[RETRY,仩URL擖椡僟僂儞儘乕僪]/
		\e"}
		}
	elseif reference0 == "m3u_d" {
		if FATTRIB((SPLITPATH(reference1)[0])+(SPLITPATH(reference1)[1]))[2] != 1 {
			"僨傿儗僋僩儕偑懚嵼偟傑偣傫丅\n[half]/
			\n丂 \q[CLOSE,仩close]乥\q[RETRY,仩弌椡愭僨傿儗僋僩儕曄峏]/
			\e"
		}
		elseif (SPLITPATH(reference1)[3])!=".m3u" {
			".m3u偺奼挘巕偑晅偄偨僷僗傪擖椡偟偰偔偩偝偄丅\n[half]/
			\n丂 \q[CLOSE,仩close]乥\q[RETRY,仩弌椡愭僨傿儗僋僩儕曄峏]/
			\e"
			}
		else {
			仜m3u弌椡僷僗=reference1
			仩嬋儕僗僩弌椡
			}
		}

  elseif reference0 == "mpath" {
	仜path=0
	仜path=reference1
		if 仜path!=0 {
		仩僼傽僀儖偑僪儘僢僾偝傟偨
		}
	}
  elseif reference0 == "mfpath" {
	仜僨傿儗僋僩儕=0
	仜path=reference1
		if (FATTRIB(仜path)[2])==1 {
		仜僨傿儗僋僩儕=仜path
		仩僨傿儗僋僩儕僪儘僢僾張棟
		}
	}
 }
}


