--
": %(傾僀僐儞2('hotkey'))摦嶌愝掕 :::::::::::::::::::::\n\n"
--


"%(傾僀僐儞2('point','仩'))僀儞傾僋僥傿僽帪%(fcl)Ctrl + Shift + Key%(def)偱僉乕憖嶌\n\n[half]"
--
if 仜儂僢僩僉乕憖嶌=="ON" {"丂丂丂丂%(fcl)ON%(def) 乵\q[曄峏,仩儂僢僩僉乕OFF]乶"}
else {"丂丂丂丂%(fcl)OFF%(def)乵\q[曄峏,仩儂僢僩僉乕ON]乶"}
--
