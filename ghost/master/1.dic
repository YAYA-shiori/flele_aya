if 仜嬋儕僗僩儊僯儏乕=="ON" {"丂丂丂丂%(fcl)ON%(def) 乵\q[曄峏,仩嬋儕僗僩儊僯儏乕OFF]乶"}
else {"丂丂丂丂%(fcl)OFF%(def)乵\q[曄峏,仩嬋儕僗僩儊僯儏乕ON]乶"}
--

"\n\n[half]/
\n丂丂丂丂丂丂丂\q[CLOSE,仩close]乥\q[BACK,仩愝掕]\e"
}



