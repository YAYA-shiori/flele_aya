}



OnFileDrop2 {
仜path=0
仜path=reference0
仩僼傽僀儖偑僪儘僢僾偝傟偨
}

仩僼傽僀儖偑僪儘僢僾偝傟偨 {
"\0"
--
	//丂僨傿儗僋僩儕偐偳偆偐敾抐
	if (FATTRIB (仜path))[2] == 1 {
	仜僨傿儗僋僩儕=0
	仜僨傿儗僋僩儕=reference0
	仩僨傿儗僋僩儕僷僗挷惍
	}
	
	//丂僨傿儗僋僩儕偠傖側偐偭偨傜僼傽僀儖偲偟偰張棟
	else {
	仜僨傿儗僋僩儕 = 0
	//丂娙堈攝楍傪斈梡攝楍傊曄姺
	仜AllFilepath = SPLIT (仜path, ",")
	仜path = (仜AllFilepath[0])
	_奼挘巕 = TOLOWER ((SPLITPATH (仜path))[3])
		// m3u傪搳偘傜傟偨
	if _奼挘巕 == ".m3u" || _奼挘巕 == ".pls" {
		仩僾儗僀儕僗僩張棟
		}
		else {
		仩僪儘僢僾僼傽僀儖張棟
		}
	}
--
"\e"
}



仩僪儘僢僾僼傽僀儖張棟 {
	_僪儘僢僾僼傽僀儖悢 = ARRAYSIZE (仜AllFilepath)
	_捛壛偟偨嬋悢 = 0
	_婛偵擖偭偰偨嬋悢 = 0
//僪儘僢僾偝傟偨僼傽僀儖攝楍偺奺梫慺抣傪弴斣偵庢傝弌偟
foreach 仜AllFilepath ; _Filename {
	//壒妝僼傽僀儖偐偳偆偐奼挘巕偱敾抐
	_奼挘巕 = TOLOWER ((SPLITPATH (_Filename))[3])
	if (ASEARCH(_奼挘巕,'.mid','.mp3','.wav','.wma','.ogg')) != -1
		{
		//僨傿儗僋僩儕僷僗偑晅偄偰側偐偭偨傜晅偗傞
		if 仜僨傿儗僋僩儕 != 0 {_Filename = 仜僨傿儗僋僩儕 + _Filename}
		
		//壒妝僼傽僀儖側傜儕僗僩偵擖偭偰偄傞偐敾抐(柍偄応崌-1)
		if (ASEARCH(_Filename,仜嬋儕僗僩)) == -1
			{
			//擖偭偰偄側偄嬋側傜儕僗僩偵捛壛
			if 仜嬋偺悢<=0 {仜嬋儕僗僩 = _Filename}
			else {仜嬋儕僗僩 = (仜嬋儕僗僩,_Filename)}
			_捛壛偟偨嬋悢++
			}
			//婛偵擖偭偰偨嬋側傜壗傕偟側偄偱僇僂儞僩
			else { _婛偵擖偭偰偨嬋悢++ }
		}

	}
//嬋捛壛偟偨応崌嬋悢曬崘
--
if _捛壛偟偨嬋悢 >= 1 {
	仜嬋儕僗僩峏怴=1
	仩僿儖僾儊僯儏乕徚柵偟偨
	--
	if 仜嬋偺悢 == 1 {仜嬋儕僗僩 = 仜嬋儕僗僩[0]}
	"\b[0]\c%(仜僒乕僼僃僗)\s[0]%(_捛壛偟偨嬋悢)嬋捛壛丅\w5\n嬋儕僗僩偵偼慡%(仜嬋偺悢)嬋擖偭偰傑偡丅"
	--
	if _捛壛偟偨嬋悢 == 1 && 仜儌乕僪 != "CD" {
	"\n\n[half]丂丂 \q[PLAY,仩僪儘僢僾嬋嵞惗]乥\q[CLOSE,仩close]"
		}
	--
	"\w9\w9\w9\w9%(仜僒乕僼僃僗)"
	}
	
//嬋捛壛偱偒側偐偭偨
else {
	仩僿儖僾儊僯儏乕徚柵偟偨
	--
	//婛偵擖偭偰偨嬋傪1偮埲忋僪儘僢僾偝傟偨
	if _婛偵擖偭偰偨嬋悢 >0	{"\b[0]\s[0]偦偺嬋偼傕偆婛偵擖偭偰偄傑偡丅\w9\w9\w9\w9%(仜僒乕僼僃僗)"}
	}
//丂僙乕僽
SAVEVAR
}

仩僪儘僢僾嬋嵞惗 {
仜巜掕嬋斣崋=仜嬋偺悢
仩嬋儔儞僟儉嵞惗
}

仩僾儗僀儕僗僩張棟 {
_f=FOPEN (仜path,"r")
_txt=0
_i=0
仜AllFilepath = IARRAY
	while _txt != -1 && _i<5000 {
	_i++
	_txt = FREAD (仜path)
	_d = _i-2
		//愭摢偵File*=偑偮偄偰偨傜嶍彍
		if (STRSTR(_txt,"File%(_d)=",0))==0 {
		_txt = REPLACE(_txt, "File%(_d)=", "")
		}
		//愭摢偵#EXTM3U傗#EXTINF傗[playlist]偑偮偄偰側偐偭偨傜仜AllFilepath偵捛壛
		if (STRSTR(_txt,"[playlist]",0))!=0 && (STRSTR(_txt,"#EXTM3U:",0))!=0 && (STRSTR(_txt,"#EXTINF:",0))!=0 && _txt!=-1 {
		仜AllFilepath = (仜AllFilepath,_txt)
		}
	}
FCLOSE (仜path)
	if (ARRAYSIZE(仜AllFilepath)) >=1 {
	仩僪儘僢僾僼傽僀儖張棟
	}
}



/// music //////////////////////////////////////////////////////

仩嬋儔儞僟儉嵞惗 {
仜僿儖僾儊僯儏乕昞帵拞=0

 //CD儌乕僪偺帪===========================
 if 仜儌乕僪 =="CD" {
 仜CD僩儔僢僋悢=(SAORI('saori\mcidonut.dll', 'trackcount'))
	if 仜CD僩儔僢僋悢 >= 1 {
			//巜掕斣崋偑偁傞応崌
			if 仜巜掕嬋斣崋>=1 {
			仜墘憈拞CD僩儔僢僋 = 仜巜掕嬋斣崋
			ERASEVAR ("仜巜掕嬋斣崋")
			}
			//僩儔僢僋悢偑1偐
			elseif 仜CD僩儔僢僋悢==1 {仜墘憈拞CD僩儔僢僋 = 1}
			elseif 仜墘憈朄=="seq_one"&&(ISVAR("仜巜掕嬋斣崋"))==0 {
			仜墘憈拞CD僩儔僢僋 = 1
			}

			elseif 仜墘憈朄=="seq_loop" {
				if 仜墘憈拞CD僩儔僢僋 == 仜CD僩儔僢僋悢 {
				仜墘憈拞CD僩儔僢僋 = 1
				}
				else {
				_i=TOINT(仜墘憈拞CD僩儔僢僋)
				仜墘憈拞CD僩儔僢僋=_i+1
				}
			}

			//2埲忋側傜慜夞嵞惗偟偨僩儔僢僋埲奜傪墘憈
			else {
				_慖戰僩儔僢僋=仜墘憈拞CD僩儔僢僋
				while _慖戰僩儔僢僋==仜墘憈拞CD僩儔僢僋 {
				_t = 仜CD僩儔僢僋悢-1
				_慖戰僩儔僢僋 = (RAND(_t))+1 
				}
			仜墘憈拞CD僩儔僢僋 = _慖戰僩儔僢僋
			}

		_e=SAORI("saori\mcidonut.dll", "stop")
		_e=SAORI("saori\mcidonut.dll", "seek", 仜墘憈拞CD僩儔僢僋)
		_e=SAORI("saori\mcidonut.dll", "play")
		仜僒乕僼僃僗 = "\s[25]"

		if 仜墘憈拞 == 0 {"\b[6]\0\b[-1]\s[25]\e"
		--
		仩僿儖僾儊僯儏乕徚柵偟偨
		}
		仜墘憈拞 = 1
		仜婲摦拞墘憈夞++
		仜嵞惗帪娫懷[hour] = (仜嵞惗帪娫懷[hour])+1
		--
		//嬋柤僂傿儞僪僂昞帵偟偰偨傜嬋柤峏怴
		仩嬋柤僂傿儞僪僂ON側傜昞帵
	}
 }
 //捠忢儌乕僪偺帪===========================
 else {
   //嬋偑堦嬋埲忋偁傟偽幚峴
   if 仜嬋偺悢 >= 1 {
   	//墘憈偟偰偄側偄忬懺偩偭偨傜壧僒乕僼僃僗偵偡傞
	if 仜墘憈拞 == 0 {"\0\b[-1]\s[25]\e"
		--
		仩僿儖僾儊僯儏乕徚柵偟偨}
	_慜夞墘憈嬋僷僗 = 仜墘憈拞嬋僷僗
		//嬋偑1嬋偟偐側偄応崌偦傟傪墘憈
		//枖偼墘憈朄偑seq_one偺応崌1偐傜墘憈
		if 仜嬋偺悢 == 1 {
			仜墘憈拞嬋僷僗 = 仜嬋儕僗僩
			仜墘憈拞嬋No = 1
		}
		elseif 仜墘憈朄 == "seq_one"&& (ISVAR("仜巜掕嬋斣崋"))==0 {
			仜墘憈拞嬋僷僗 = 仜嬋儕僗僩[0]
			仜墘憈拞嬋No = 1
		}
		elseif (ISVAR("仜巜掕嬋斣崋"))==1 {
			仜墘憈拞嬋僷僗 = 仜嬋儕僗僩[(仜巜掕嬋斣崋-1)]
			仜墘憈拞嬋No = 仜巜掕嬋斣崋
		}
		//嬋偑2嬋埲忋偁傞応崌儔儞僟儉墘憈
		else {
		_墘憈偡傞嬋僷僗 = (ANY(仜嬋儕僗僩))
		仜墘憈拞嬋No = TOINT(LSO+1)
			//慜夞偲堘偆嬋傪慖傇傑偱儖乕僾
			while _墘憈偡傞嬋僷僗 == _慜夞墘憈嬋僷僗 {
			_墘憈偡傞嬋僷僗 = (ANY(仜嬋儕僗僩))
			仜墘憈拞嬋No = TOINT(LSO+1)
			}
		仜墘憈拞嬋僷僗 = _墘憈偡傞嬋僷僗
		}
	//慖傫偩僼傽僀儖傪墘憈
	_i=SAORI("saori\mciaudior.dll", "load", "%(仜墘憈拞嬋僷僗)")
	_i=SAORI("saori\mciaudior.dll", "play")
	仜嵞惗帪娫懷[hour] = TOINT((仜嵞惗帪娫懷[hour])+1)
	仜僒乕僼僃僗 = "\s[25]"
	仜墘憈拞 = 1
	仜婲摦拞墘憈夞++
	ERASEVAR ("仜巜掕嬋斣崋")
