		仩嬋儔儞僟儉嵞惗
		}
	}
	elseif 仜墘憈朄 == "seq_loop" {
		if 仜嬋偺悢 == 仜墘憈拞嬋No {
		仜巜掕嬋斣崋=1
		仩嬋儔儞僟儉嵞惗
